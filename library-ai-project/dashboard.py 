import streamlit as st
import pandas as pd
import plotly.express as px

st.set_page_config(page_title="Sistema de Biblioteca Inteligente", layout="wide")
st.title("📚 Panel de Analitica de Biblioteca (Edades 3 - 110 anos)")

try:
    df = pd.read_csv("library_inventory.csv")
    
    col1, col2 = st.columns(2)
    with col1:
        st.markdown("**Edad Promedio de los Lectores por Libro**")
        fig_barras = px.bar(df, x="titulo", y="edad_promedio_lector", color="genero", text="edad_promedio_lector", template="plotly_white")
        st.plotly_chart(fig_barras, use_container_width=True)
    with col2:
        st.markdown("**Distribucion de Libros Disponibles por Pasillo**")
        fig_pie = px.pie(df, values="cantidad", names="ubicacion", hole=0.4, template="plotly_white")
        st.plotly_chart(fig_pie, use_container_width=True)
        
    st.dataframe(df, use_container_width=True)
except Exception as e:
    st.error(f"Error cargando los datos: {e}")
